<configuration>
  <system.webServer>
    <!-- iisnode: flushResponse required for Server-Sent Events (SSE) streaming -->
    <iisnode flushResponse="true" />
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode"/>
    </handlers>
    <rewrite>
      <rules>
        <rule name="StaticContent" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="server.js"/>
        </rule>
      </rules>
      <outboundRules>
        <!-- CRA hashed assets in /static/ → aggressive 1-year immutable cache -->
        <rule name="CacheHashedAssets" preCondition="IsHashedStaticAsset">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="public, max-age=31536000, immutable" />
        </rule>
        <!-- HTML files → no-cache (SPA must always get fresh index.html) -->
        <rule name="NoCacheHtml" preCondition="IsHtmlFile">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-cache, no-store, must-revalidate" />
        </rule>
        <preConditions>
          <preCondition name="IsHashedStaticAsset">
            <add input="{REQUEST_URI}" pattern="/static/" />
          </preCondition>
          <preCondition name="IsHtmlFile">
            <add input="{REQUEST_URI}" pattern="\.html?$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <!-- Warm-up: ping /health so Node boots without hitting /server.js directly -->
    <applicationInitialization doAppInitAfterRestart="true">
      <add initializationPage="/health" />
    </applicationInitialization>

    <!-- Enable IIS-level compression for static + dynamic content -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    <httpCompression>
      <dynamicTypes>
        <add mimeType="text/event-stream" enabled="false" />
      </dynamicTypes>
    </httpCompression>

    <!-- Remove X-Powered-By header -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <!-- Default document should be the SPA index, not server.js (which is handled via rewrite) -->
    <defaultDocument>
      <files>
        <clear/>
        <add value="index.html" />
        <add value="index.htm" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
