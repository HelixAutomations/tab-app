{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Teams App Locally",
			"dependsOn": [
				"Validate prerequisites",
				"Provision",
				"Deploy",
				"Start application"
			],
			"dependsOrder": "sequence"
		},
		{
			"label": "Validate prerequisites",
			"type": "teamsfx",
			"command": "debug-check-prerequisites",
			"args": {
				"prerequisites": [
					"nodejs",
					"m365Account",
					"portOccupancy"
				],
				"portOccupancy": [
					53000,
					9229
				]
			}
		},
		{
			"label": "Provision",
			"type": "teamsfx",
			"command": "provision",
			"args": {
				"env": "local"
			}
		},
		{
			"label": "Deploy",
			"type": "teamsfx",
			"command": "deploy",
			"args": {
				"env": "local"
			}
		},
		{
			"label": "Start application",
			"dependsOn": [
				"Start frontend"
			]
		},
		{
			"label": "Start frontend",
			"type": "shell",
			"command": "npm run dev:fast",
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 0,
					"location": 1,
					"message": 2
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Compiled|Failed|compiled|failed"
				}
			}
		},
		{
			"label": "Debug: Query annual leave (BOD)",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/debugAnnualLeaveBOD.mjs"
			],
			"isBackground": false
		},
		{
			"label": "Debug: Query annual leave (BOD) (full)",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/debugAnnualLeaveBOD.mjs"
			],
			"isBackground": false
		},
		{
			"label": "Debug: Query annual leave (BOD) summary",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/debugAnnualLeaveBOD.mjs"
			],
			"isBackground": false
		},
		{
			"label": "Debug: Query annual leave (BOD) summary 2",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/debugAnnualLeaveBOD.mjs"
			],
			"isBackground": false
		}
	]
}