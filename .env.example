# .env.example
# 
# Copy this file to .env and fill in your actual values
# This file is safe to commit to git (no secrets)
#

# Database Connection Strings (replace with your actual credentials)
SQL_CONNECTION_STRING=Server=tcp:your-database-server.database.windows.net,1433;Initial Catalog=your-database;Persist Security Info=False;User ID=your-username;Password=YOUR_PASSWORD;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Instructions Database Connection (separate from main database)
INSTRUCTIONS_SQL_CONNECTION_STRING=Server=tcp:your-instructions-server.database.windows.net,1433;Initial Catalog=instructions;Persist Security Info=False;User ID=your-username;Password=YOUR_PASSWORD;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Azure Configuration
REACT_APP_KV_URI=https://your-keyvault.vault.azure.net/
ALLOWED_ORIGINS=https://teams.microsoft.com,https://your-app.azurewebsites.net
SYSTEM_TRIAGE_STAGING_LOG_ANALYTICS_WORKSPACE_ID=your-staging-log-analytics-workspace-id
SYSTEM_TRIAGE_STAGING_LOG_ANALYTICS_ROLES=link-hub-v1,helix-hub-server

# Azure AD Configuration
AZURE_TENANT_ID=your-tenant-id-here

# Secret Names (for Key Vault references)
SQL_SERVER_PASSWORD_KEY=sql-databaseserver-password
GRAPH_EMAIL_PROVIDER_CLIENT_ID=graph-pitchbuilderemailprovider-clientid
GRAPH_EMAIL_PROVIDER_CLIENT_SECRET=graph-pitchbuilderemailprovider-clientsecret-v2
GRAPH_AIDEN_CLIENT_ID=graph-aidenteams-clientid
TEAM_HUB_NOTIFICATION_TENANT_ID=team-hub-notification-tenant-id
TEAM_HUB_NOTIFICATION_APP_ID=team-hub-notification-app-id
TEAM_HUB_NOTIFICATION_CLIENT_SECRET=team-hub-notification-client-secret

# Development Settings
USE_LOCAL_SECRETS=false
REACT_APP_USE_LOCAL_DATA=false

# Replace with your initials and actual secrets
AC_AUTOMATIONS_APITOKEN=your-api-token-here
YOUR_INITIALS_CLIO_V1_CLIENTID=your-clio-client-id
YOUR_INITIALS_CLIO_V1_CLIENTSECRET=your-clio-client-secret
YOUR_INITIALS_CLIO_V1_REFRESHTOKEN=your-clio-refresh-token

# Redis (Microsoft Entra ID) authentication
# Set REDIS_USER to the Object ID (GUID) of the user/service principal that has Data Access on the Redis cache.
# Optionally set REDIS_TENANT_ID to the tenant ID of the cache to ensure tokens are acquired from the correct directory.
REDIS_USER=your-redis-user-object-id
REDIS_TENANT_ID=your-tenant-id

# GA4 integration
GA4_PROPERTY_ID=your-ga4-property-id
GA4_SERVICE_ACCOUNT_SECRET=ga4-service-account-json

# ─── Demo / Rehearsal-record safety (Phase C1 + C2) ───────────────────────
# Brief: docs/notes/HELIX_REHEARSAL_RECORD_LUKE_TEST_AS_FIRM_SEED.md (§Phase C)
# Runbook: .github/instructions/DEMO_MODE_REFERENCE.md
#
# When set to 1/true/yes/on, /api/clio-contacts and /api/clio-matters
# short-circuit on rehearsal/demo refs (HLX-27367-*, DEMO-*, HLX-DEMO-*) and
# return synthetic dryRun:true payloads instead of writing to Clio. Emits
# `Demo.Clio.WriteSkipped` to App Insights.
#
# Defaulted to 1 here because local + dev-loop is where demo refs are
# overwhelmingly exercised and an accidental Clio write during a demo costs
# real cleanup. Production deploys MUST explicitly set this to 0 (or unset)
# in App Service config — `build-and-deploy.ps1` does not propagate this.
CLIO_DRY_RUN_FOR_REHEARSAL_REFS=1

# Split NetDocuments destination folder by ref. CCL uploads against rehearsal
# refs route to *_REHEARSAL; everything else routes to *_PROD. Falls back to
# legacy CCL_ND_UPLOAD_FOLDER for back-compat if either is missing.
CCL_ND_UPLOAD_FOLDER_REHEARSAL=
CCL_ND_UPLOAD_FOLDER_PROD=
CCL_ND_UPLOAD_FOLDER=