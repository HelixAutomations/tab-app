# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# This repo includes TeamsFx + Node + Azure Functions. Keep secrets, local state,
# build artifacts, and scratch files out of git.

# Environment / secrets
.env
.env.*
!.env.example
.env.local
.secrets-cache.json

# TeamsFx files
env/.env.*.user
env/.env.local
env/.env.*
.localConfigs
api/local.settings.json

# OS / editor
.DS_Store

# Dependencies
node_modules/
**/node_modules/

# Testing
coverage/

# Builds / deployment artifacts
build/
appPackage/build/
deploy/
deploy-staging/
build.zip
*.zip

# Azurite
azurite/
azurite/debug.log
__azurite_db_*.json
__blobstorage__/
__queuestorage__/

# Local data / generated assets
src/localData/
data/roadmap-whiteboard.json
data/roadmap-whiteboard.archive.json
public/ccls/*.docx
src/assets/signatures/

# Server logs
server/logs/

# Personal project - never commit
submodules/typefxce/

# Scratch / temporary files (repo root)
.tmp/
temp_*
temp.*
prod-settings.txt

# Legacy scripts directory (intentionally excluded)
scripts/
!scripts/
scripts/*
!scripts/generate-search-marketing-value-snapshot-pdf.mjs

# Generated CCL artefacts
logs/ccl-outputs/

logs/ccl-drafts/
logs/dev-all/
logs/
